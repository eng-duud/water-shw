# Neon PostgreSQL connection strings
# DATABASE_URL: Pooled connection for Next.js app queries (use -pooler in hostname)
DATABASE_URL="postgresql://neondb_owner:your_pooled_password@ep-cool-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# DIRECT_URL: Direct connection for migrations (no -pooler in hostname)
DIRECT_URL="postgresql://neondb_owner:your_direct_password@ep-cool.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Cloudinary Unsigned Upload Credentials
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET="your-unsigned-upload-preset"

# SaaS / Tenant Readiness Identifier
NEXT_PUBLIC_TENANT_ID="ghayl-al-diya"
